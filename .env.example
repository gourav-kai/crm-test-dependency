# Environment Variables

## Backend
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=7d

## Frontend
# The frontend will proxy /api to http://localhost:4000 in dev mode
# Set VITE_API_URL to override (optional, only needed for production)
# VITE_API_URL=http://localhost:4000
